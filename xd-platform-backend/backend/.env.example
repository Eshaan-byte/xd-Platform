# Server Configuration
NODE_ENV=production
PORT=5001
CORS_ORIGIN=*

# Database - MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/game-platform

# JWT Secret
JWT_SECRET=your-secret-key-here

# RAWG API (free key from https://rawg.io/apidocs)
RAWG_API_KEY=your-rawg-key-here

# Logging
LOG_LEVEL=info
