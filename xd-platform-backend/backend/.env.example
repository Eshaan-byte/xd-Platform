# Server Configuration
NODE_ENV=development
PORT=5001
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Database - Local MongoDB (MongoDB Compass)
MONGODB_URI=mongodb://localhost:27017/game-platform

# JWT Secret (required — used for email/password auth)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Firebase Admin SDK (optional — for Firebase auth support)
# Get these from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# AWS S3 Configuration (optional — for game file storage)
# Create IAM user with S3 permissions and generate access keys
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# Logging
LOG_LEVEL=debug
